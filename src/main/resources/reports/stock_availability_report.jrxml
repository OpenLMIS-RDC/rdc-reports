	<parameter name="headerTemplate" class="net.sf.jasperreports.engine.JasperReport" isForPrompting="false"/>
	<queryString>
		<![CDATA[WITH
latest_orderable_identifiers AS (
    SELECT DISTINCT ON (orderableid)
        orderableid, value, orderableversionnumber
    FROM referencedata.orderable_identifiers
    WHERE "key" = 'tradeItem'
    ORDER BY orderableid, orderableversionnumber DESC
),
user_rights AS (
    SELECT facilityid, programid, userid
    FROM referencedata.right_assignments ra
    WHERE ra.rightname = 'STOCK_CARDS_VIEW' AND ra.userId = $P{userId}::uuid
),
products_allowed AS (
    SELECT
        DISTINCT(products.id) AS productid,
        MAX(products.versionnumber) AS productversionnumber,
        facilities.id AS facilityid
    FROM referencedata.orderables AS products
    JOIN stockmanagement.stock_cards AS sc ON products.id = sc.orderableid
    JOIN stockmanagement.stock_card_line_items AS scli ON sc.id = scli.stockcardid
    JOIN referencedata.facilities AS facilities ON facilities.id = sc.facilityid
    JOIN referencedata.facility_types AS facilities_types ON facilities_types.id = facilities.typeid
    JOIN referencedata.geographic_zones AS zones ON zones.id = facilities.geographiczoneid
    JOIN referencedata.programs AS programs ON sc.programid = programs.id
    JOIN user_rights AS ur ON programs.id = ur.programid
        AND facilities.id = ur.facilityid
    JOIN latest_orderable_identifiers AS orderable_identifiers ON
        products.id = orderable_identifiers.orderableid
        AND products.versionnumber = orderable_identifiers.orderableversionnumber
    WHERE
        (facilities.name = $P{facility}::varchar OR $P{facility}::varchar IS NULL)
        AND (programs.name = $P{program}::varchar OR $P{program}::varchar IS NULL)
        AND (
            ($P{endDate}::date IS NOT NULL AND scli.occurreddate <= $P{endDate}::date)
            OR $P{endDate}::date IS NULL
        )
    GROUP BY products.id, facilities.id
),
soh_data AS (
    SELECT
        products.id AS productid,
        f.id AS facilityid,
        SUM(soh.stockonhand) AS stockonhand
    FROM stockmanagement.stock_cards AS stock_cards
    JOIN stockmanagement.calculated_stocks_on_hand AS soh ON soh.stockcardid = stock_cards.id
    JOIN (
        SELECT
            stockcardid,
            MAX(occurreddate) AS max_date
        FROM
            stockmanagement.calculated_stocks_on_hand
        WHERE
            occurreddate <= $P{endDate}::date
        GROUP BY
            stockcardid
    ) AS cs ON cs.stockcardid = soh.stockcardid AND cs.max_date = soh.occurreddate
    JOIN referencedata.orderables products ON products.id = stock_cards.orderableid
    JOIN referencedata.facilities f ON stock_cards.facilityid = f.id
    JOIN products_allowed pa ON products.id = pa.productid
        AND products.versionnumber = pa.productversionnumber
        AND stock_cards.facilityid = pa.facilityid
    GROUP BY products.id, f.id
),
stock_data AS (
    SELECT
        sc.orderableid AS productid,
        sc.facilityid AS facilityid,
        csoh.occurreddate AS occurreddate,
        MIN(csoh.stockonhand)::integer AS stockonhand
    FROM stockmanagement.calculated_stocks_on_hand csoh
    INNER JOIN stockmanagement.stock_cards sc ON csoh.stockcardid = sc.id
    JOIN products_allowed pa ON sc.orderableid = pa.productid
        AND sc.facilityid = pa.facilityid
    WHERE csoh.occurreddate <= $P{endDate}::date
    GROUP BY sc.orderableid, sc.facilityid, csoh.occurreddate
),
stock_data_with_lag AS (
    SELECT
        productid,
        facilityid,
        occurreddate,
        stockonhand,
        LAG(stockonhand) OVER (
            PARTITION BY productid, facilityid
            ORDER BY occurreddate
        ) AS prev_stockonhand,
        LEAD(occurreddate) OVER (
            PARTITION BY productid, facilityid
            ORDER BY occurreddate
        ) AS nextdate
    FROM stock_data
),
last_before_period AS (
    SELECT productid, facilityid, occurreddate AS last_date, stockonhand
    FROM (
        SELECT productid, facilityid, occurreddate, stockonhand,
            ROW_NUMBER() OVER (PARTITION BY productid, facilityid ORDER BY occurreddate DESC) AS rn
        FROM stock_data
        WHERE occurreddate < $P{startDate}::date
    ) ranked
    WHERE rn = 1
),
first_in_period AS (
    SELECT productid, facilityid, occurreddate AS first_date, stockonhand
    FROM (
        SELECT productid, facilityid, occurreddate, stockonhand,
            ROW_NUMBER() OVER (PARTITION BY productid, facilityid ORDER BY occurreddate ASC) AS rn
        FROM stock_data
        WHERE occurreddate >= $P{startDate}::date
    ) ranked
    WHERE rn = 1
),
stockout_calc AS (
    SELECT
        pf.productid,
        pf.facilityid,
        lb.last_date AS last_before_date,
        lb.stockonhand AS last_before_soh,
        fp.first_date AS first_in_period_date,
        fp.stockonhand AS first_in_period_soh
    FROM products_allowed pf
    LEFT JOIN last_before_period lb ON pf.productid = lb.productid AND pf.facilityid = lb.facilityid
    LEFT JOIN first_in_period fp ON pf.productid = fp.productid AND pf.facilityid = fp.facilityid
),
stockout_case1 AS (
    -- Case 1: Last record before period shows stock <= 0 -> count from period start
    SELECT
        productid,
        facilityid,
        CASE
            WHEN first_in_period_date IS NOT NULL
            THEN first_in_period_date - $P{startDate}::date
            ELSE ($P{endDate}::date + 1) - $P{startDate}::date
        END AS stockout_days
    FROM stockout_calc
    WHERE last_before_date IS NOT NULL
        AND last_before_soh <= 0
        AND (first_in_period_date IS NULL OR first_in_period_date > $P{startDate}::date)
),
stockout_case2 AS (
    -- Case 2: Gap at start - only if there was NO prior stock data at all
    -- If last stock before period existed and was > 0, assume stock continues (no stockout)
    SELECT
        productid,
        facilityid,
        first_in_period_date - $P{startDate}::date AS stockout_days
    FROM stockout_calc
    WHERE first_in_period_date IS NOT NULL
        AND first_in_period_date > $P{startDate}::date
        AND last_before_date IS NULL
),
stockout_case3 AS (
    -- Case 3: Within-period stockouts (using LAG detection)
    SELECT
        productid,
        facilityid,
        SUM(
            CASE WHEN (prev_stockonhand IS NULL OR prev_stockonhand > 0) AND stockonhand <= 0
                THEN LEAST(COALESCE(nextdate, $P{endDate}::date + 1), $P{endDate}::date + 1) - GREATEST(occurreddate, $P{startDate}::date)
                ELSE 0 END
        ) AS stockout_days
    FROM stock_data_with_lag
    WHERE stockonhand <= 0
        AND occurreddate >= $P{startDate}::date
        AND occurreddate <= $P{endDate}::date
    GROUP BY productid, facilityid
),
stockout_combined AS (
    SELECT productid, facilityid, SUM(stockout_days) AS totalstockoutdays
    FROM (
        SELECT productid, facilityid, stockout_days FROM stockout_case1
        UNION ALL
        SELECT productid, facilityid, stockout_days FROM stockout_case2
        UNION ALL
        SELECT productid, facilityid, COALESCE(stockout_days, 0) FROM stockout_case3
    ) combined
    GROUP BY productid, facilityid
),
amc_data AS (
    WITH monthly_consumption AS (
        SELECT
            date_trunc('month', scli.occurreddate)::date AS month_date,
            sc.orderableid AS productid,
            sc.facilityid,
            SUM(ABS(scli.quantity)) FILTER (
                WHERE scli.destinationid IS NOT NULL OR sclir.reasontype = 'DEBIT'
            ) AS consumption,
            COUNT(DISTINCT scli.occurreddate::date) AS active_days
        FROM stockmanagement.stock_card_line_items scli
        JOIN stockmanagement.stock_cards sc ON scli.stockcardid = sc.id
        JOIN products_allowed pa ON sc.orderableid = pa.productid
            AND sc.facilityid = pa.facilityid
        LEFT JOIN stockmanagement.stock_card_line_item_reasons sclir ON scli.reasonid = sclir.id
        WHERE scli.occurreddate >= ($P{endDate}::date - INTERVAL '3 months')
            AND scli.occurreddate < date_trunc('month', $P{endDate}::date)
        GROUP BY date_trunc('month', scli.occurreddate)::date, sc.orderableid, sc.facilityid
    )
    SELECT
        mc.productid,
        mc.facilityid,
        ROUND(AVG(mc.consumption), 2) AS amc
    FROM monthly_consumption mc
    WHERE mc.month_date >= ($P{endDate}::date - INTERVAL '3 months')
        AND mc.month_date < date_trunc('month', $P{endDate}::date)
    GROUP BY mc.productid, mc.facilityid
)
SELECT
    products.code AS productCode,
    products.fullproductname AS productName,
    product_categories.displayname AS productCategoryName,
    facilities.name AS facilityName,
    COALESCE(soh.stockonhand, 0) AS stockOnHand,
    COALESCE(amc.amc, 0) AS averageMonthlyConsumption,
    COALESCE(sa.totalstockoutdays, 0) AS stockoutDays,
    CASE
        WHEN amc.amc > 0 THEN ROUND(COALESCE(soh.stockonhand, 0)::numeric / amc.amc, 2)
        ELSE 0
    END AS monthOfStock
FROM referencedata.orderables AS products
JOIN products_allowed AS pa ON products.id = pa.productid
    AND products.versionnumber = pa.productversionnumber
LEFT JOIN soh_data AS soh
    ON products.id = soh.productid AND pa.facilityid = soh.facilityid
LEFT JOIN amc_data AS amc
    ON products.id = amc.productid AND pa.facilityid = amc.facilityid
LEFT JOIN stockout_combined AS sa
    ON products.id = sa.productid AND pa.facilityid = sa.facilityid
LEFT JOIN referencedata.facilities AS facilities ON facilities.id = pa.facilityid
LEFT JOIN (
    SELECT DISTINCT ON (orderableid)
        orderableid, orderableversionnumber, orderabledisplaycategoryid
    FROM referencedata.program_orderables
) AS program_orderables ON
    program_orderables.orderableid = products.id
    AND program_orderables.orderableversionnumber = products.versionnumber
LEFT JOIN referencedata.orderable_display_categories AS product_categories ON
    product_categories.id = program_orderables.orderabledisplaycategoryid
ORDER BY facilities.name, products.code]]>
	</queryString>
	<field name="facilityName" class="java.lang.String"/>
	<field name="productName" class="java.lang.String"/>
	<field name="productCode" class="java.lang.String"/>
	<field name="productCategoryName" class="java.lang.String"/>
	<field name="stockoutDays" class="java.lang.String"/>
	<field name="stockOnHand" class="java.lang.String"/>
	<field name="monthOfStock" class="java.lang.String"/>
