	<parameter name="headerTemplate" class="net.sf.jasperreports.engine.JasperReport" isForPrompting="false"/>
	<queryString>
		<![CDATA[SELECT
            f.name AS facilityName,
            c.model AS model,
            c.type AS type,
            c.netvolume AS netVolume,
            i.referencename AS referenceName,
            p.name AS program,
            i.equipmenttrackingid AS serialNo,
            i.yearofinstallation AS yearOfInstallation,
            i.yearofwarrantyexpiry AS yearOfWarrantyExpiry,
            i.functionalstatus AS functionalStatus
        FROM cce.cce_inventory_items i
        JOIN cce.cce_catalog_items c ON c.id = i.catalogitemid
        JOIN referencedata.facilities f ON f.id = i.facilityid
        JOIN referencedata.programs p ON p.id = i.programid
        WHERE
            (f.name = $P{facility}::varchar OR $P{facility}::varchar IS NULL)
            AND (p.name = $P{program}::varchar OR $P{program}::varchar IS NULL)
            AND (
                ($P{date}::date IS NOT NULL AND i.modifieddate <= $P{date}::date)
                OR $P{date}::date IS NULL
            )]]>
	</queryString>
